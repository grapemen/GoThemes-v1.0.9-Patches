			<div id="char-copy" style="display: none;">
				<h2>Copy a character</h2>
				<p>Have a character ID? Use it here!</p>
				<input type="text" value="400001035" name="char-id">
				<a href="#" onclick="copyRedirect()">Copy</a>
			</div>
			<form>
     <input id="importer-files" type="file" name="file" title="Upload Files" accept=".mp3,.wav,.ogg,.wma,.swf,.gif,.png,.jpg,.mp4" style="display:none">
</form>
		

