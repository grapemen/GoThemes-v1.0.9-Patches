<!DOCTYPE html>
<html>
  <head>
    <meta charset="UTF-8" />
    <link rel="icon" href="/favicon.ico" type="image/png" />
    <title>Video List - GoThemes</title>
    <meta name="description" content="GoThemes's Video List" />
    <link rel="stylesheet" type="text/css" href="/pages/css/global.css" />
    <link rel="stylesheet" type="text/css" href="/pages/css/list.css" />
    <script src="/pages/js/jquery.js"></script>
    <script src="/pages/js/global.js"></script>
  </head>

  <body>
    <%~ includeFile("./includes/header", { env: it.env }) %>

    <main>
      <table class="full_screen">
        <thead>
          <tr>
            <td></td>
            <td>Video Title</td>
            <td>Last Modified</td>
            <td></td>
          </tr>
        </thead>
        <tbody></tbody>
        <tfoot>
          <tr>
            <td colspan="127">
              <a id="load_more" href="javascript:;">LOAD MORE...</a>
            </td>
          </tr>
        </tfoot>
      </table>
    </main>

    <%~ includeFile("./includes/footer", { env: it.env }) %>
  </body>

  <script>
    let settings = {};
    $.get("/api/settings/list", (data) => {
      settings = data;
    });
  </script>

  <script>
    let json;
    const tbody = $("tbody");
    const loadMore = $("#load_more");

    let C = 0;
    function loadRows() {
      // load only 69 rows
      let c = C;
      C += 69;
      for (; c < C; c++) {
        // we reached the end
        if (c > json.length - 1) {
          loadMore.remove();
          break;
        }

        const tbl = json[c];
        // make the date and time less confusing to read
        const date = tbl.date.split("T")[0];
        const time = tbl.date.split("T")[1].substring(0, 8);
        // escape the title
        const title = tbl.title
          .replace(/&/g, "&amp;")
          .replace(/</g, "&lt;")
          .replace(/>/g, "&gt;");

        tbody.append(
          `<tr id="${tbl.id}">
    		<td>
    			<img src="/file/movie/thumb/${tbl.id}" alt="thumbnail"/>
    		</td>
    		<td>
    			<div>${title}</div>
    			<div>${tbl.duration}</div>
    		</td>
    		<td>
    			<span>${date}, ${time}</span>
    		</td>
    		<td>
    			<a href="javascript:;" onclick="popup('${tbl.id}')"></a>
    			<a href="/go_full?movieId=${tbl.id}"></a>
    			<a href="/file/movie/file/${tbl.id}" download="${tbl.title}.zip"></a>
    			<a href="#" onclick="destructive('${tbl.id}', 'repair')"></a>
    			<a href="#" onclick="destructive('${tbl.id}', 'delete')"></a>
    			<a href="goexport://?video_id=${tbl.id}&service=local_beta&no_input=1&resolution=480p&aspect_ratio=16:9&open_folder=true&use_outro=false"></a>
    		</td>
    	</tr>`.trim()
        );
      }
    }

    // i want more movies
    loadMore.onclick = loadRows;

    $.get("/api/movies/list", (data) => {
      json = data;
      loadRows();
    });

    function destructive(mId, act) {
        $.get(`/api/movie/${act}/${mId}`, (data) => {
          if (data.status == "ok") {
            switch (act) {
              case "repair":
                window.location = `/player?movieId=${mId}`;
                break;
              case "delete":
                $(`#${mId}`).fadeOut(() => $(`#${mId}`).remove());
                break;
            }
          } else alert("UCfzfqRrGe_1GuxdHcOwdp9w");
        });
    }

    function popup(id) {
      window.open(
        "/watch?v=" + id,
        "MsgWindow",
        "width=1280,height=720,left=" +
          (screen.width / 2 - 640) +
          ",top=" +
          (screen.height / 2 - 360)
      );
    }
  </script>
</html>